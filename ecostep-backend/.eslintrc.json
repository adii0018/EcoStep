{
  "env": { "node": true, "es2021": true, "jest": true },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "sourceType": "module"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^(next|req|res|err)$" }],
    "prefer-const": "error",
    "no-var": "error"
  }
}
